{
  "$schema": "vscode://schemas/color-theme",
  "name": "Dogppuccin Latte (Husky)",
  "type": "light",
  "colors": {
    "editor.background": "#E8ECF1",
    "editor.foreground": "#2C2C2C",
    "editorCursor.foreground": "#3F6A8A",
    "editor.selectionBackground": "#A9B4C240",
    "editor.lineHighlightBackground": "#F2F5F7",
    "editorLineNumber.foreground": "#A9B4C2",
    "editorWhitespace.foreground": "#A9B4C2",
    "sideBar.background": "#F2F5F7",
    "sideBar.foreground": "#2C2C2C",
    "activityBar.background": "#A9B4C2",
    "activityBar.foreground": "#F2F5F7",
    "activityBarBadge.background": "#6BAED6",
    "activityBarBadge.foreground": "#F2F5F7",
    "statusBar.background": "#4A5563",
    "statusBar.foreground": "#f2f5f7",
    "titleBar.activeBackground": "#A9B4C2",
    "titleBar.activeForeground": "#2C2C2C",
    "button.background": "#6BAED6",
    "button.foreground": "#F2F5F7",
    "button.hoverBackground": "#3F6A8A",
    "input.background": "#F2F5F7",
    "input.foreground": "#2C2C2C",
    "input.border": "#A9B4C2",
    "panel.background": "#E8ECF1",
    "panel.border": "#A9B4C2",
    "terminal.background": "#E8ECF1",
    "terminal.foreground": "#2C2C2C",
    "terminalCursor.foreground": "#3F6A8A",
    "focusBorder": "#6BAED6"
  },
  "tokenColors": [
    { "scope": ["comment"], "settings": { "foreground": "#A9B4C2" } },
    { "scope": ["keyword", "storage.type"], "settings": { "foreground": "#3F6A8A" } },
    { "scope": ["string"], "settings": { "foreground": "#6BAED6" } },
    { "scope": ["variable", "identifier"], "settings": { "foreground": "#2C2C2C" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#5A4F4C" } },
    { "scope": ["entity.name.function"], "settings": { "foreground": "#4A5563" } },
    { "scope": ["entity.name.type"], "settings": { "foreground": "#3F6A8A" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#2C2C2C" } }
  ]
}
